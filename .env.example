# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://jobpulse:jobpulse@localhost:5432/jobpulse

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
# Bot mode: "polling" (default) or "webhook"
BOT_MODE=polling
# Webhook URL (required if BOT_MODE=webhook)
# BOT_WEBHOOK_URL=https://your-domain.com/webhook-path
# BOT_WEBHOOK_PORT=8443
# BOT_LISTEN_PORT=3000

# ─── Source Adapters: Indeed ──────────────────────────────────────────────────
INDEED_API_KEY=your_indeed_publisher_api_key

# ─── Source Adapters: Greenhouse ──────────────────────────────────────────────
# Comma-separated board tokens
GREENHOUSE_BOARD_TOKENS=board_token_1,board_token_2

# ─── Source Adapters: Lever ───────────────────────────────────────────────────
# Comma-separated company IDs
LEVER_COMPANY_IDS=company_id_1,company_id_2

# ─── Source Adapters: LinkedIn ────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=your_linkedin_oauth_token

# ─── Monitor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
POLL_QUEUE_NAME=job-polls
MAX_CONCURRENT_POLLS=5
HEALTH_CHECK_PORT=9090

# ─── API Server (Fastify) ─────────────────────────────────────────────────────
API_PORT=3001

# ─── CLI Configuration (can also be set via `jobpulse config set`) ────────────
# JOBPULSE_API_KEY=your_api_key
# JOBPULSE_THEME=dark

# ─── Ops Alerting ─────────────────────────────────────────────────────────────
# Webhook URL for source degradation alerts (optional)
# OPS_WEBHOOK_URL=https://hooks.example.com/ops-alerts

# ─── General ──────────────────────────────────────────────────────────────────
# Set to "1" to disable color output in CLI
# NO_COLOR=1
